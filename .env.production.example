# ─── Banco de dados ───────────────────────────────────────────────────────────
DB_USER=easy_process_user
DB_PASSWORD=TROQUE_POR_SENHA_FORTE
DB_NAME=easy_process_prod
DATABASE_URL=postgresql+asyncpg://easy_process_user:TROQUE_POR_SENHA_FORTE@db:5432/easy_process_prod

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=GERE_UM_SECRET_FORTE_AQUI
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── APIs de IA ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Whisper ──────────────────────────────────────────────────────────────────
# Para produção considere "small" para melhor qualidade em pt-BR
WHISPER_MODEL=base

# ─── Upload ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_SIZE_MB=100

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Substitua pelo seu domínio real
CORS_ORIGINS=["https://seudominio.com"]

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://seudominio.com

# ─── Ambiente ─────────────────────────────────────────────────────────────────
ENVIRONMENT=production
